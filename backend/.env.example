# ============================================
# 环境变量配置（SQLite 版本）
# ============================================
# Railway 部署时无需任何数据库插件，开箱即用。
# 数据存储在 Railway Volume 持久化卷中。
# ============================================

# 数据库连接（留空则自动使用默认 SQLite 路径）
# DATABASE_URL=sqlite:///data/supermarket.db

# JWT 密钥（生产环境必须修改为随机字符串！）
SECRET_KEY=your-secret-key-change-in-production

# 调试模式（生产环境设为 False）
DEBUG=False
