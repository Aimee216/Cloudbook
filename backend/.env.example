# Railway 部署环境变量配置
# 在 Railway Dashboard 中设置以下变量

# MySQL 数据库配置（使用 Railway MySQL 插件时自动注入 DATABASE_URL）
DATABASE_URL=mysql+pymysql://root:password@host:3306/supermarket?charset=utf8mb4

# 如果手动配置 MySQL，可以使用以下独立变量
# DB_HOST=
# DB_PORT=3306
# DB_USER=
# DB_PASSWORD=
# DB_NAME=supermarket

# Redis 配置（可选，使用 Railway Redis 插件时自动注入 REDIS_URL）
# REDIS_HOST=
# REDIS_PORT=6379
# REDIS_PASSWORD=

# JWT 密钥（生产环境必须修改）
SECRET_KEY=your-secret-key-change-in-production

# 调试模式（生产环境设为 False）
DEBUG=False