# ============================================
# Railway 部署环境变量配置
# ============================================
# 以下变量需要在 Railway Dashboard -> Variables 中设置
#
# 注意：若使用 Railway MySQL 插件，DATABASE_URL 会自动注入，无需手动设置。
#       若使用 Railway Redis 插件，REDIS_URL 会自动注入，无需手动设置。
# ============================================

# MySQL 数据库连接（Railway MySQL 插件会自动注入 DATABASE_URL）
# 格式: mysql+pymysql://user:password@host:port/dbname?charset=utf8mb4
# DATABASE_URL=mysql+pymysql://root:password@host:3306/supermarket?charset=utf8mb4

# 手动配置 MySQL（当未使用 Railway MySQL 插件时）
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=supermarket

# JWT 密钥（生产环境必须修改为随机字符串！）
SECRET_KEY=your-secret-key-change-in-production

# 调试模式（生产环境设为 False）
DEBUG=False
