{
  "$schema": "https://railway.app/railway.schema.json",
  "services": {
    "Cloudbook": {
      "root": "backend",
      "builder": "NIXPACKS",
      "deploy": {
        "startCommand": "uvicorn app:app --host 0.0.0.0 --port $PORT",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
      }
    }
  }
}